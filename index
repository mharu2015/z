<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clarion Hyper Cyber Launcher</title>
    <style>
        /* 全体の基本設定 */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Consolas', 'Courier New', monospace; /* カクカクしたフォント */
            background: #000000;
            color: #ffffff;
            overflow: hidden;
            height: 100vh;
            perspective: 1200px; /* 3D奥行き */
            user-select: none;
        }

        /* サイバー感を出す背景の格子（グリッド） */
        .cyber-grid {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
            background-position: center;
            pointer-events: none;
            z-index: 1;
        }

        /* ==========================================
           1. 起動画面（超カクカク 3Dワープ）
           ========================================== */
        .opening-screen {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: #000000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 20px;
            transform-style: preserve-3d;
            /* 4.2秒後に音速で奥へ引きずり込まれるカクカクアニメーション */
            animation: hyperZoomOut 0.8s cubic-bezier(0.85, 0, 0.15, 1) 4.2s forwards;
        }

        /* ダイヤモンド・サイバーロゴ */
        .logo-container {
            position: relative;
            margin-bottom: 50px;
        }

        .logo {
            font-size: 72px;
            font-weight: 900;
            font-style: italic;
            letter-spacing: 12px;
            color: #00e5ff;
            text-transform: uppercase;
            position: relative;
            /* メタリック＆クリスタルな鋭いグラデーション */
            background: linear-gradient(135deg, #00e5ff 20%, #ffffff 45%, #00e5ff 55%, #0055ff 80%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            /* ダイヤモンドの激しいフラッシュと、カクカクした電子ノイズ */
            animation: 
                diamondFlash 1.8s linear infinite,
                glitchNoise 4s steps(2) infinite; /* steps(2)でカクカク動かす */
        }

        /* シャープな注意書き */
        .warning-text {
            font-size: 13px;
            color: #00e5ff;
            letter-spacing: 2px;
            line-height: 2.2;
            text-align: center;
            max-width: 600px;
            border: 1px solid rgba(0, 229, 255, 0.2);
            padding: 20px 40px;
            background: rgba(0, 20, 40, 0.6);
            box-shadow: inset 0 0 15px rgba(0, 229, 255, 0.1);
            opacity: 0;
            /* カクっと現れる（1秒後に一瞬で表示） */
            animation: suddenIn 0.1s steps(1) 1s forwards;
        }

        /* ==========================================
           2. メインメニュー画面（SFコックピット風）
           ========================================== */
        .menu-screen {
            width: 100vw; height: 100vh;
            background: radial-gradient(circle at center, #021125 0%, #000205 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 2;
            opacity: 0;
            /* 起動画面が消えた瞬間に、爆速で手前に飛び出す */
            animation: hyperMenuIn 0.6s cubic-bezier(0.1, 1, 0.1, 1) 4.3s forwards;
            padding: 20px;
        }

        .menu-title {
            font-size: 16px;
            font-weight: bold;
            letter-spacing: 8px;
            color: #00e5ff;
            margin-bottom: 60px;
            text-shadow: 0 0 10px #00e5ff;
        }

        /* メニューのグリッドレイアウト */
        .grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 35px;
            width: 100%;
            max-width: 500px;
        }

        /* コックピットのスイッチ風ボタン */
        .menu-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: #ffffff;
            height: 140px;
            background: linear-gradient(135deg, #05162c 0%, #010710 100%);
            border: 2px solid #0055ff;
            border-radius: 4px; /* カクカク感を出すため丸みを減らす */
            box-shadow: 0 0 15px rgba(0, 85, 255, 0.3);
            cursor: pointer;
            position: relative;
            transition: all 0.1s steps(2); /* タップ時もカクカク反応 */
        }

        /* ボタンの角にサイバー風の装飾 */
        .menu-btn::before {
            content: ''; position: absolute;
            top: -2px; left: -2px; width: 10px; height: 10px;
            border-top: 3px solid #00e5ff; border-left: 3px solid #00e5ff;
        }

        .icon {
            font-size: 44px;
            margin-bottom: 12px;
            filter: drop-shadow(0 0 8px #0055ff);
        }

        .label {
            font-size: 13px;
            font-weight: 900;
            letter-spacing: 4px;
            color: #00e5ff;
            text-shadow: 0 0 5px rgba(0, 229, 255, 0.5);
        }

        /* タップ（トリガー）した瞬間 */
        .menu-btn:active {
            transform: scale(0.92);
            background: #00e5ff;
            border-color: #ffffff;
            box-shadow: 0 0 30px #00e5ff;
        }
        .menu-btn:active .label, .menu-btn:active .icon {
            color: #000000;
            filter: none;
            text-shadow: none;
        }

        /* ==========================================
           ⚡ ハイパー・サイバー・アニメーション
           ========================================== */
        
        /* ① ダイヤモンドの超閃光 */
        @keyframes diamondFlash {
            0% { background-position: 200% center; }
            100% { background-position: -200% center; }
        }

        /* ② カクカクしたデジタルノイズ（位置がブレる） */
        @keyframes glitchNoise {
            0%, 92%, 100% { transform: translate(0, 0) skew(0deg); filter: blur(0); }
            93% { transform: translate(5px, -3px) skew(10deg); filter: hue-rotate(90deg); }
            95% { transform: translate(-5px, 3px) skew(-10deg); }
            97% { transform: translate(2px, 2px); filter: blur(1px); }
        }

        /* ③ 注意書きがカクっと一瞬で表示 */
        @keyframes suddenIn {
            to { opacity: 1; }
        }

        /* ④ 絶叫ズームアウト（奈落の底へカクカク吸い込まれる） */
        @keyframes hyperZoomOut {
            0% {
                opacity: 1;
                transform: translateZ(0) scale(1) rotate(0deg);
            }
            40% {
                /* 手前にカクっと引いてタメを作る */
                transform: translateZ(50px) scale(1.05);
                opacity: 1;
            }
            100% {
                /* 次元を超えて奥へ消滅 */
                transform: translateZ(-1500px) scale(0.1) rotate(-10deg);
                opacity: 0;
                visibility: hidden;
            }
        }

        /* ⑤ メニュー画面が超高速で手前にドカンと出現 */
        @keyframes hyperMenuIn {
            from {
                opacity: 0;
                transform: translateZ(400px) scale(0.8);
            }
            to {
                opacity: 1;
                transform: translateZ(0) scale(1);
            }
        }
    </style>
</head>
<body>

    <div class="cyber-grid"></div>

    <div class="opening-screen">
        <div class="logo-container">
            <div class="logo">Clarion</div>
        </div>
        <div class="warning-text">
            [WARNING] SYSTEM CHECK COMPLETE.<br>
            ALWAYS OBEY TRAFFIC LAWS AND REGULATIONS.<br>
            DO NOT OPERATE WHILE DRIVING.
        </div>
    </div>

    <div class="menu-screen">
        <div class="menu-title">// COCKPIT CONTROL PANEL //</div>
        
        <div class="grid">
            
            <a href="intent://#Intent;scheme=android-app;package=jp.pioneer.mbg.covertamnavi;end" class="menu-btn">
                <div class="icon">🗺️</div>
                <div class="label">DRIVE_MAP</div>
            </a>

            <a href="intent://#Intent;scheme=android-app;package=com.google.android.apps.youtube.music;end" class="menu-btn">
                <div class="icon">🎵</div>
                <div class="label">AUDIO_SYS</div>
            </a>

        </div>
    </div>

</body>
</html>
